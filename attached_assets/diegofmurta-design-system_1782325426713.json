{
  "meta": {
    "source": "diegofmurta.com",
    "title": "Diego Fontes",
    "type": "Portfolio de diretor/produtor audivisual",
    "approach": "Dark theme, tipografia condensada e pesada (Helvetica Neue), layout editorial com vídeos",
    "colorSpace": "oklch + hex/rgba"
  },

  "colors": {
    "tokens": {
      "--bg": "#000",
      "--bg-2": "#000",
      "--fg": "oklch(0.97 0.004 80)",
      "--muted": "oklch(0.72 0.004 80)",
      "--faint": "oklch(0.45 0.004 80)",
      "--line": "oklch(1 0 0 / 0.12)",
      "accent-green": "oklch(0.72 0.16 145)"
    },
    "roles": {
      "background": "#000 (preto puro)",
      "textPrimary": "--fg (off-white quase branco, levemente quente)",
      "textSecondary": "--muted (cinza claro)",
      "textTertiary": "--faint (cinza médio/escuro, usado em índices e eyebrows)",
      "border": "--line (branco a 12% de opacidade)",
      "accent": "accent-green (verde, usado em dot de navegação e indicador de som ligado)"
    },
    "overlays": {
      "heroScrim": "linear-gradient(to top, rgba(0,0,0,.78) 0%, rgba(0,0,0,.08) 42%, rgba(0,0,0,.30) 100%)",
      "tileScrim": "linear-gradient(to top, rgba(0,0,0,.6), rgba(0,0,0,0) 48%)",
      "ctaBackground": "rgba(255,255,255,0.04)",
      "videoButtonBg": "rgba(0,0,0,.4)",
      "videoButtonBgHover": "rgba(0,0,0,.62)"
    },
    "selection": {
      "background": "--fg",
      "color": "--bg"
    }
  },

  "typography": {
    "families": {
      "--display": "'Helvetica Neue', Helvetica, Arial, sans-serif",
      "--ui": "'Helvetica Neue', Helvetica, Arial, sans-serif"
    },
    "globalDirection": {
      "bodyFontWeight": 700,
      "bodyLetterSpacing": "-0.004em",
      "displayWeight": 800,
      "displayFontStretch": "condensed",
      "fontSmoothing": "antialiased",
      "textRendering": "optimizeLegibility"
    },
    "scale": {
      "label": {
        "fontSize": "clamp(10px, 0.78vw, 12px)",
        "fontWeight": 700,
        "letterSpacing": "0.22em",
        "textTransform": "uppercase",
        "uso": "Kickers, eyebrows, metadados, links de navegação"
      },
      "brand": {
        "fontSize": "clamp(20px, 1.8vw, 26px)",
        "fontWeight": 800,
        "letterSpacing": "0.04em",
        "lineHeight": 1
      },
      "h1.headline": {
        "fontSize": "clamp(40px, 9.4vw, 150px)",
        "fontWeight": 800,
        "lineHeight": 0.86,
        "letterSpacing": "-0.03em",
        "textTransform": "uppercase",
        "maxWidth": "15ch",
        "textWrap": "balance"
      },
      "work-head h2 (FILM)": {
        "fontSize": "clamp(34px, 6vw, 92px)",
        "fontWeight": 800,
        "lineHeight": 0.9,
        "letterSpacing": "-0.02em",
        "textTransform": "uppercase"
      },
      "marquee item": {
        "fontSize": "clamp(26px, 4.4vw, 64px)",
        "fontWeight": 800,
        "letterSpacing": "-0.02em",
        "textTransform": "uppercase"
      },
      "tile-meta ttitle": {
        "fontSize": "clamp(30px, 4.6vw, 76px)",
        "fontWeight": 800,
        "lineHeight": 0.9,
        "letterSpacing": "-0.02em",
        "textTransform": "uppercase"
      },
      "project h2 (título do filme)": {
        "fontSize": "clamp(30px, 4.4vw, 68px)",
        "fontWeight": 800,
        "lineHeight": 0.92,
        "letterSpacing": "-0.02em",
        "textTransform": "uppercase"
      },
      "pdesc (descrição)": {
        "fontSize": "clamp(13px, 1vw, 15px)",
        "lineHeight": 1.55,
        "maxWidth": "42ch",
        "color": "--muted"
      },
      "spec value": {
        "fontSize": "clamp(13px, 1vw, 15px)",
        "fontWeight": 500
      },
      "foot-mark (LET'S CREATE.)": {
        "fontSize": "clamp(54px, 13vw, 230px)",
        "fontSizeInline": "120px",
        "fontWeight": 800,
        "lineHeight": 0.86,
        "letterSpacing": "-0.01em a -0.6px",
        "textTransform": "uppercase",
        "whiteSpace": "nowrap"
      }
    },
    "mobileOverrides": {
      "foot-mark": "clamp(44px, 15vw, 92px), whiteSpace normal, lineHeight 0.9",
      "h1.headline": "lineHeight 0.9"
    }
  },

  "spacing": {
    "--pad": "clamp(20px, 4.5vw, 64px)",
    "padraoFluido": "Espaçamentos usam clamp() para escala fluida entre mobile e desktop",
    "exemplos": {
      "navPadding": "clamp(18px, 2.6vw, 30px) var(--pad)",
      "workSection": "clamp(56px, 9vh, 130px) var(--pad) 0",
      "projectPadding": "clamp(40px, 7vh, 96px) 0",
      "footerPadding": "clamp(70px, 12vh, 150px) var(--pad) clamp(34px, 5vh, 56px)",
      "gridGap": "clamp(12px, 1.4vw, 22px)"
    }
  },

  "layout": {
    "hero": {
      "height": "100svh (mobile: auto)",
      "minHeight": "560px",
      "video": "object-fit: contain, object-position: top center"
    },
    "workGrid": {
      "desktop": "grid 2 colunas (1fr 1fr)",
      "mobile": "1 coluna (<760px)",
      "tileAspectRatio": "4/5 (mobile 3/4)"
    },
    "projectList": {
      "desktop": "grid 1.4fr 1fr, alternando ordem em :nth-child(even)",
      "mediaAspectRatio": "16/9",
      "mobile": "1 coluna (<860px), sem alternância"
    },
    "breakpoints": {
      "tablet": "860px (project list colapsa)",
      "mobile": "760px (work grid colapsa, nav simplifica, hero reestrutura)"
    }
  },

  "components": {
    "nav": {
      "position": "fixed top",
      "mixBlendMode": "difference",
      "estilo": "Transparente sobre conteúdo, texto branco que inverte cor pelo fundo",
      "dot": "5px círculo verde (accent)"
    },
    "label/eyebrow": {
      "estilo": "Uppercase, bold, letter-spacing largo (0.22em), tamanho pequeno"
    },
    "tile (card de trabalho)": {
      "aspectRatio": "4/5",
      "hover": "image-slot scale(1.045) + filter brightness(.82) ao longo de 1.1s",
      "scrim": "gradiente preto na base",
      "easing": "cubic-bezier(.16,.84,.34,1)"
    },
    "cta (botão pill no tile)": {
      "borderRadius": "100px",
      "border": "1px solid --line",
      "backdropFilter": "blur(6px)",
      "background": "rgba(255,255,255,0.04)",
      "estado": "opacity 0 → 1 e translateY(8px) → 0 no hover do tile",
      "hover": "fundo --fg, texto --bg"
    },
    "pmedia (player de vídeo do projeto)": {
      "aspectRatio": "16/9",
      "video": "object-fit: cover, autoplay muted em viewport",
      "hover": "image-slot scale(1.05) + brightness; vídeo brightness(.92)"
    },
    "vmute (botão de som)": {
      "background": "rgba(0,0,0,.4) + backdrop-filter blur(4px)",
      "indicador": "dot 7px — cinza (muted) quando mudo, verde (accent) quando som ligado"
    },
    "watch-link": {
      "estilo": "pill outline, border-radius 100px, ícone play SVG",
      "hover": "fundo --fg, texto --bg, translateY(-1px)"
    },
    "pspecs": {
      "estilo": "Linha de specs (Year/Role/Format) com borda superior --line, chave em --faint e valor em --fg"
    },
    "marquee (faixa de logos)": {
      "estilo": "Logos em escala de cinza (opacity 0.45) que ficam coloridos no hover",
      "comportamento": "Loop infinito horizontal, pausa no hover"
    },
    "footer": {
      "wordmark": "LET'S CREATE. em escala gigante",
      "footRow": "Borda superior --line, linha de metadados/links"
    },
    "grain": {
      "estilo": "Textura de ruído SVG (feTurbulence fractalNoise) sobre o hero, mix-blend-mode overlay, opacity 0.5"
    }
  },

  "animations": {
    "keyframes": {
      "slide": {
        "uso": "Barra animada do scroll-cue (LEO POLLEX)",
        "duracao": "2.4s",
        "easing": "cubic-bezier(.7,0,.3,1)",
        "loop": "infinite",
        "movimento": "translateX(-110%) → 260%"
      },
      "marquee": {
        "uso": "Faixa de logos de clientes",
        "duracao": "32s",
        "easing": "linear",
        "loop": "infinite",
        "movimento": "translateX(0) → -50% (loop sem emenda via duplicação)",
        "pauseOnHover": true
      }
    },
    "reveal": {
      "uso": "[data-reveal] — entrada de elementos no scroll",
      "estadoInicial": "opacity 0, translateY(26px)",
      "estadoFinal": "opacity 1, translateY(0)",
      "duracao": "1s",
      "easing": "cubic-bezier(.2,.7,.2,1)",
      "trigger": "IntersectionObserver (threshold 0.18)"
    },
    "transitions": {
      "tileImageHover": "transform 1.1s cubic-bezier(.16,.84,.34,1), filter .6s ease",
      "ctaHover": "opacity .5s, transform .5s, background .3s",
      "linkHover": "opacity/color .3s",
      "watchLinkHover": "background/color/border/transform .3s"
    },
    "easingPalette": {
      "smoothEntrada": "cubic-bezier(.2,.7,.2,1)",
      "imagemZoom": "cubic-bezier(.16,.84,.34,1)",
      "barraScroll": "cubic-bezier(.7,0,.3,1)"
    },
    "accessibility": {
      "prefersReducedMotion": "Desativa reveal, animação da barra e do marquee"
    }
  },

  "effects": {
    "backdropBlur": ["blur(6px) no CTA", "blur(4px) nos botões de vídeo"],
    "mixBlendMode": ["difference (nav)", "overlay (grain do hero)"],
    "textStroke": "-webkit-text-stroke originalmente usado em .em, mas sobrescrito para preenchimento sólido",
    "scrollBehavior": "smooth",
    "overflow": "overflow-x: clip no body"
  }
}
